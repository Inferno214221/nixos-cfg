{
  "multi_cursor_modifier": "cmd_or_ctrl",
  "collaboration_panel": {
    "dock": "left"
  },
  "buffer_font_weight": 450.0,
  "show_whitespaces": "selection",
  "diagnostics": {
    "inline": {
      "enabled": false
    }
  },
  "base_keymap": "None",
  "diff_view_style": "split",
  "restore_on_startup": "last_session",
  "show_edit_predictions": false,
  "preferred_line_length": 100,
  "soft_wrap": "none",
  "toolbar": {
    "code_actions": true
  },
  "relative_line_numbers": "disabled",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "project_panel": {
    "dock": "left",
    "default_width": 270.0,
    "hide_hidden": false,
    "hide_root": false,
    "bold_folder_labels": false,
    "indent_size": 15.0,
    "file_icons": true,
    "entry_spacing": "standard"
  },
  "git_panel": {
    "dock": "left",
    "default_width": 270.0,
    "tree_view": true
  },
  "outline_panel": {
    "auto_reveal_entries": true,
    "indent_guides": {
      "show": "always"
    },
    "auto_fold_dirs": true,
    "dock": "right"
  },
  "debugger": {
    "dock": "right"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "text_rendering_mode": "grayscale",
  "terminal": {
    "dock": "right",
    "toolbar": {
      "breadcrumbs": true
    },
    "font_weight": 400.0,
    "font_family": "MesloLGS NF"
  },
  "semantic_tokens": "combined",
  "session": {
    "trust_all_worktrees": true
  },
  "load_direnv": "shell_hook",
  "ui_font_weight": 400.0,
  "ui_font_family": "Ubuntu",
  "ui_font_size": 16.0,
  "buffer_line_height": "standard",
  "format_on_save": "off",
  "minimap": {
    "show": "auto"
  },
  "colorize_brackets": true,
  "auto_update": false,
  "buffer_font_family": "DejaVu Sans Mono",
  "use_system_window_tabs": false,
  "window_decorations": "client",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "buffer_font_size": 14.0,
  "tab_size": 4,
  "wrap_guides": [
    100
  ],
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "languages": {
    "JSONC": {
      "tab_size": 2,
    },
    "JSON": {
      "tab_size": 2,
    },
    "Nix": {
      "tab_size": 2,
      "remove_trailing_whitespace_on_save": true,
    },
    "YAML": {
      "tab_size": 2
    },
    "XML": {
      "tab_size": 2,
      "wrap_guides": [
        80
      ],
      "soft_wrap": "editor_width",
    },
    "HTML": {
      "tab_size": 2,
      "soft_wrap": "bounded",
    },
    "Markdown": {
      "tab_size": 2,
      "soft_wrap": "bounded",
    },
    "Typst": {
      "tab_size": 2,
      "soft_wrap": "bounded",
      "remove_trailing_whitespace_on_save": true,
    },
    "Rust": {
      "remove_trailing_whitespace_on_save": true,
    }
  },
  "icon_theme": "VSCode Icons for Zed (Dark Official Icons)",
  "theme": "Kali Dark",
  "auto_install_extensions": {
    "clean-vscode-icons": true,
    "codebook": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "material-icon-theme": true,
    "nix": true,
    "php": true,
    "sql": true,
    "toml": true,
    "typst": true,
    "vscode-icons": true,
    "xml": true,
    "lisette": true,
  },
  "lsp": {
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true
          }
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    }
  }
}
