{
  "diagnostics": {
    "inline": {
      "enabled": false
    }
  },
  "base_keymap": "None",
  "diff_view_style": "split",
  "restore_on_startup": "last_session",
  "show_edit_predictions": false,
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": true,
  "preferred_line_length": 100,
  "soft_wrap": "none",
  "toolbar": {
    "code_actions": true
  },
  "relative_line_numbers": "disabled",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "project_panel": {
    "dock": "left",
    "default_width": 270.0,
    "hide_hidden": false,
    "hide_root": false,
    "bold_folder_labels": false,
    "indent_size": 15.0,
    "file_icons": true,
    "entry_spacing": "standard"
  },
  "git_panel": {
    "default_width": 270.0,
    "tree_view": true
  },
  "outline_panel": {
    "auto_reveal_entries": true,
    "indent_guides": {
      "show": "always"
    },
    "auto_fold_dirs": true,
    "dock": "right"
  },
  "debugger": {
    "dock": "right"
  },
  "agent": {
    "show_turn_stats": true,
    "play_sound_when_agent_done": true,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "text_rendering_mode": "grayscale",
  "terminal": {
    "dock": "right",
    "toolbar": {
      "breadcrumbs": true
    },
    "font_weight": 400.0,
    "font_family": "MesloLGS NF"
  },
  "semantic_tokens": "combined",
  "session": {
    "trust_all_worktrees": true
  },
  "load_direnv": "shell_hook",
  "ui_font_weight": 400.0,
  "ui_font_family": "Ubuntu",
  "ui_font_size": 16.0,
  "buffer_line_height": "standard",
  "format_on_save": "off",
  "minimap": {
    "show": "auto"
  },
  "colorize_brackets": true,
  "auto_update": false,
  "buffer_font_family": "DroidSansM Nerd Font Mono",
  "use_system_window_tabs": false,
  "window_decorations": "client",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "buffer_font_size": 14.0,
  "tab_size": 4,
  "wrap_guides": [
    100
  ],
  "languages": {
    "JSONC": {
      "tab_size": 2
    },
    "JSON": {
      "tab_size": 2
    },
    "XML": {
      "tab_size": 2,
      "wrap_guides": [
        80
      ]
    },
    "HTML": {
      "tab_size": 2
    },
    "Markdown": {
      "tab_size": 2
    },
    "Nix": {
      "tab_size": 2
    }
  },
  "icon_theme": "VSCode Icons for Zed (Dark Official Icons)",
  "theme": "Kali Dark",
  "theme_overrides": {
    "One Dark": {
      "border": "#16171EFF",
      "border.variant": "#16171EFF",
      "border.focused": "#2777FFFF",
      "border.selected": "#2777FFFF",
      "border.disabled": "#1A1C23FF",
      "elevated_surface.background": "#1A1C23FF",
      "surface.background": "#1A1C23FF",
      "background": "#16171EFF",
      "element.background": "#323643FF",
      "element.hover": "#23252EFF",
      "element.active": "#2777FFFF",
      "element.selected": "#23252EFF",
      "ghost_element.hover": "#23252EDD",
      "ghost_element.active": "#2777FFFF",
      "ghost_element.selected": "#23252EFF",
      "ghost_element.disabled": "#23252EDD",
      "text": "#EEEEECFF",
      "text.muted": "#BBBBBDFF",
      "text.placeholder": "#878A98FF",
      "text.disabled": "#888A8DFF",
      "text.accent": "#6AA1FCFF",
      "icon": "#EEEEECFF",
      "icon.muted": "#BBBBBDFF",
      "icon.disabled": "#888A8DFF",
      "icon.accent": "#6AA1FCFF",
      "status_bar.background": "#16171EFF",
