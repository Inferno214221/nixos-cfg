      "editor.active_line.background": "#16171EBF",
      "editor.highlighted_line.background": "#1A1C23FF",
      "editor.line_number": "#636D83FF",
      "editor.active_line_number": "#FFCC00FF",
      "editor.hover_line_number": "#888A8DFF",
      "terminal.background": "#272A34FF",
      "terminal.foreground": "#EEEEECFF",
      "terminal.bright_foreground": "#FFFFFFFF",
      "terminal.dim_foreground": "#BBBBBDFF",
      "terminal.ansi.black": "#171421FF",
      "terminal.ansi.bright_black": "#5E5C64FF",
      "terminal.ansi.red": "#C01C28FF",
      "terminal.ansi.bright_red": "#F66151FF",
      "terminal.ansi.green": "#26A269FF",
      "terminal.ansi.bright_green": "#33DA7AFF",
      "terminal.ansi.yellow": "#A2734CFF",
      "terminal.ansi.bright_yellow": "#E9AD0CFF",
      "terminal.ansi.blue": "#12488BFF",
      "terminal.ansi.bright_blue": "#2A7BDEFF",
      "terminal.ansi.dim_blue": "#203C57FF",
      "terminal.ansi.magenta": "#A347BAFF",
      "terminal.ansi.bright_magenta": "#C061CBFF",
      "terminal.ansi.cyan": "#2AA1B3FF",
      "terminal.ansi.bright_cyan": "#6ED5DEFF",
      "terminal.ansi.white": "#D0CFCCFF",
      "terminal.ansi.bright_white": "#FFFFFFFF",
      "link_text.hover": "#6AA1FCFF",
