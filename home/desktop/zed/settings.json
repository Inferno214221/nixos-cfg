      "version_control.deleted": "#B55151FF",
      "modified": "#199FFDFF",
      "modified.background": "#199FFD1A",
      "modified.border": "#0B4063FF",
      "syntax": {
        "attribute": {
          "color": "#CE9887FF"
        },
        "boolean": {
          "color": "#10B1FEFF"
        },
        "comment": {
