          "color": "#FF6480FF"
        },
        "function": {
          "color": "#3FC56BFF"
        },
        "keyword": {
          "color": "#10B1FEFF"
        },
        "label": {
          "color": "#CE9887FF"
        },
        "link_text": {
          "color": "#73ADE9FF"
        },
        "lifetime": {
          "color": "#10B1FEFF"
        },
        "namespace": {
          "color": "#ABB2BFFF"
        },
        "number": {
          "color": "#FF78F8FF"
        },
        "operator": {
          "color": "#7A82DAFF"
        },
        "property": {
          "color": "#CE9887FF"
        },
        "punctuation": {
          "color": "#7A82DAFF"
        },
        "punctuation.bracket": {
          "color": "#28E4EBFF"
        },
        "punctuation.delimiter": {
          "color": "#7A82DAFF"
        },
        "punctuation.special": {
          "color": "#7A82DAFF"
        },
        "string": {
          "color": "#F9C859FF"
        },
        "string.escape": {
          "color": "#FF936AFF"
        },
        "tag": {
          "color": "#10B1FEFF"
        },
        "text.literal": {
          "color": "#F9C859FF"
        },
        "type": {
          "color": "#FF6480FF"
        },
        "variable": {
          "color": "#ABB2BFFF"
        },
        "variable.special": {
          "color": "#10B1FEFF"
        },
        "variant": {
          "color": "#9F7EFEFF"
        }
      },
      "scrollbar.thumb.active_background": "#C1D9FF35",
      "panel.overlay_background": "#1A1C23FF",
      "panel.overlay_hover": "#16171EFF",
      "minimap.thumb.background": "#C1D9FF14",
      "minimap.thumb.hover_background": "#C1D9FF28",
      "minimap.thumb.active_background": "#C1D9FF35"
    }
  },
  "auto_install_extensions": {
    "clean-vscode-icons": true,
    "html": true,
    "java": true,
    "material-icon-theme": true,
    "nix": true,
    "php": true,
    "sql": true,
    "toml": true,
    "typst": true,
    "vscode-icons": true,
    "xml": true
  },
  "lsp": {
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true
          }
        }
      }
    }
  }
}
